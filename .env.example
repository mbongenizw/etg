# ETG Fleet Management System - Environment Configuration
#
# LOCAL DEVELOPMENT (SQLite)
# Database: SQLite file-based
# Location: ./db/custom.db
# Usage: bun run dev

DATABASE_URL="file:./db/custom.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-key-change-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PRODUCTION (PostgreSQL)
# Database: PostgreSQL cloud
# Usage: Vercel deployment
# Get connection string from:
# - Neon: https://neon.tech
# - Supabase: https://supabase.com
# - Vercel Postgres: Built-in
DATABASE_URL_PRODUCTION="postgresql://user:password@host:5432/database?sslmode=require"

# Production settings
NODE_ENV="production"
